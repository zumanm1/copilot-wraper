# ============================================================
# Container 4 — Cline AI Coding Agent Terminal
#
# Official source: https://www.npmjs.com/package/cline
# Cline is an autonomous AI coding agent (formerly claude-dev)
# configured to use Container 1 as the OpenAI-compatible backend.
#
# Usage:
#   docker compose run --rm cline-terminal
#   docker compose run --rm cline-terminal bash
#   docker compose run --rm cline-terminal ask "question"
#   docker compose run --rm cline-terminal calc "10m + 5m + 500k"
# ============================================================
FROM node:20-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates bash python3 procps \
    && rm -rf /var/lib/apt/lists/*

# ── Install Cline CLI from official npm registry ──────────────
# Source: https://www.npmjs.com/package/cline
RUN npm install -g cline 2>&1 | tail -3 \
    && echo "✅ Cline installed: $(cline --version 2>/dev/null || echo 'version check pending')" \
    || echo "⚠️  Cline install had warnings — continuing"

# ── Git identity (required by Cline for file operations) ──────
RUN git config --global user.email "agent@copilot-wrapper" && \
    git config --global user.name "Cline Agent" && \
    git config --global init.defaultBranch main && \
    git config --global core.editor "true"

WORKDIR /workspace

COPY cline-terminal/ /cline-terminal/
RUN chmod +x /cline-terminal/start.sh

ENTRYPOINT ["/cline-terminal/start.sh"]
