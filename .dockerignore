# ============================================================
# Docker ignore — keeps images lean and secure
# ============================================================

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test artifacts
tests/reports/
test-reports/
*.html
.pytest_cache/
.coverage
htmlcov/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Git
.git/
.gitignore
.gitattributes

# Environment files (passed via docker-compose env_file, not baked in)
.env
.env.*
!.env.example

# Docs / media
README.md
*.md
*.png
*.jpg
*.jpeg
*.gif

# Docker files themselves (don't need them inside the image)
Dockerfile*
docker-compose*.yml
.dockerignore
