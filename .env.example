# Microsoft Copilot OpenAI Wrapper Configuration
# Copy this file to .env and fill in your values

# ── Cookies (auto-managed by cookie_manager/service.py) ──────────────────────
# These are updated automatically every 15 minutes by the cookie manager.
# Run once: bash cookie_manager/setup.sh
#
# Manual fallback: copy _U cookie from browser DevTools → bing.com cookies
BING_COOKIES=your_bing_cookies_here

# ChatGPT session cookies (auto-extracted from chrome/firefox)
CHATGPT_COOKIES=auto-extracted-by-cookie-manager

# Claude.ai session cookies (auto-extracted from chrome/firefox)
CLAUDE_COOKIES=auto-extracted-by-cookie-manager

# Copilot conversation style: creative, balanced, precise
COPILOT_STYLE=balanced

# Copilot persona: copilot, bing
COPILOT_PERSONA=copilot

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Optional: API key for authentication (leave empty to disable)
API_KEY=

# Optional: Use HTTP/HTTPS proxy
USE_PROXY=false
