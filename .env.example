# Microsoft Copilot OpenAI Wrapper Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Bing.com cookies for authentication
# To get cookies:
# 1. Go to https://copilot.microsoft.com in your browser
# 2. Sign in with your Microsoft account
# 3. Open Developer Tools (F12)
# 4. Go to Application > Cookies > https://copilot.microsoft.com
# 5. Copy the _U cookie value
BING_COOKIES=your_bing_cookies_here

# Copilot conversation style: creative, balanced, precise
COPILOT_STYLE=balanced

# Copilot persona: copilot, bing
COPILOT_PERSONA=copilot

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Optional: API key for authentication (leave empty to disable)
API_KEY=

# Optional: Use HTTP/HTTPS proxy
USE_PROXY=false
