# ============================================================
# Container 3 (C3): Headless Chrome Cookie Extractor
#
# Uses Playwright + Chromium to:
#   1. Launch a headed browser (via noVNC/VNC for visibility)
#   2. Navigate to copilot.microsoft.com
#   3. Wait for user to authenticate (if not already)
#   4. Extract all session cookies via CDP
#   5. POST them to Container 1 (/v1/reload-config)
#
# Access the browser UI at: http://localhost:6080 (noVNC)
# Trigger extraction:        POST http://localhost:8001/extract
# ============================================================

FROM mcr.microsoft.com/playwright/python:v1.44.0-jammy

# Prevent interactive apt prompts (fixes tzdata hang)
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

WORKDIR /browser-auth

# Install VNC + noVNC for headed browser access via web browser
RUN apt-get update && apt-get install -y --no-install-recommends \
    x11vnc \
    xvfb \
    novnc \
    net-tools \
    python3-websockify \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps
COPY browser_auth/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Playwright Chromium is pre-installed in the base image
# but we ensure it's present and updated
RUN playwright install chromium --with-deps 2>/dev/null || playwright install chromium

# Copy application code
COPY browser_auth/ .

# Make entrypoint executable
RUN chmod +x /browser-auth/entrypoint.sh

# Create browser profile directory
RUN mkdir -p /browser-profile

# noVNC web UI on 6080, FastAPI cookie API on 8001
EXPOSE 6080 8001

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
    CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8001/health')" || exit 1

CMD ["/browser-auth/entrypoint.sh"]
